# Port servera (API)
PORT=5000

# Host for listening
# 0.0.0.0 - all network interfaces (local network access)
# 127.0.0.1 - only localhost (local access)
HOST<0.0.0.0

# URL API for frontend (set your computer IP)
# VITE_API_URL=http://192.168.1.100:5000

# Allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://192.168.1.100:3000,http://192.168.1.100:5173

# Cache TTL (ms)
CACHE_TTL=30000

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Sentry DSN (optional)
# VITE_SENTRY_DSN=

# App version
VITE_APP_VERSION=0.2.0
